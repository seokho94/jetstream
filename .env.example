# Copy to .env and fill in. Phase 0 runs with seed data even without these.

# Postgres (pgvector + pgcrypto required)
DATABASE_URL=postgresql://meridian:meridian@localhost:5432/meridian

# Serving API the web client reads (Phase 0: stub returns seed data)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Pipeline (Phase 1+). Verify current model ids in the Claude docs before pinning.
ANTHROPIC_API_KEY=
SYNTHESIS_MODEL=claude-sonnet-4-6
SYNTHESIS_MODEL_HARD=claude-opus-4-8
EMBED_MODEL=bge-m3
EMBED_REVISION=v1.5

# GDELT discovery (Phase 0: one vertical, whitelist-scoped)
GDELT_VERTICAL=geopolitics
